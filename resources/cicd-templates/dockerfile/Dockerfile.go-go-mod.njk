# Stage 1: Build
FROM golang:{{ language_version }}-alpine AS builder
WORKDIR /app
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build -o /app/bin/{{ project_name }} ./...

# Stage 2: Runtime
FROM alpine:latest
WORKDIR /app
RUN addgroup -S appgroup && adduser -S appuser -G appgroup
COPY --from=builder /app/bin/{{ project_name }} .
USER appuser
EXPOSE {{ framework_port }}
HEALTHCHECK --interval=30s --timeout=5s --retries=3 \
  CMD wget -qO- http://localhost:{{ framework_port }}{{ health_path }} || exit 1
ENTRYPOINT ["./{{ project_name }}"]
