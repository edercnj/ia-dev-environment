# Stage 1: Build
FROM python:{{ language_version }}-slim AS builder
WORKDIR /app
COPY pyproject.toml setup.cfg* ./
RUN pip install --no-cache-dir --prefix=/install .
COPY . .
RUN pip install --no-cache-dir --prefix=/install .

# Stage 2: Runtime
FROM {{ docker_base_image }}
WORKDIR /app
RUN groupadd -r appgroup && useradd -r -g appgroup appuser
COPY --from=builder /install /usr/local
COPY . .
USER appuser
EXPOSE {{ framework_port }}
HEALTHCHECK --interval=30s --timeout=5s --retries=3 \
  CMD python -c "import urllib.request; urllib.request.urlopen('http://localhost:{{ framework_port }}{{ health_path }}')" || exit 1
ENTRYPOINT ["python", "-m", "{{ project_name }}"]
