# macOS
.DS_Store

# FUSE hidden files
.fuse_hidden*

.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# GitHub Copilot — generated output of the boilerplate (except CI workflows)
.github/*
!.github/workflows/

# OS files
.DS_Store
Thumbs.db

# Editor files
*.swp
*.swo
*~
.idea/
.vscode/
*.iml

# Temporary files
*.tmp
*.bak

# Java
java/target/
java/dependency-reduced-pom.xml
*.class
*.jar
!java/lib/*.jar

# Maven
.mvn/timing.properties
.mvn/wrapper/maven-wrapper.jar

# Coverage
java/target/site/
*.exec

# Test output
test-output/
test-output-ts/
output/
# Re-include Java source 'output' directories (hexagonal architecture ports/adapters)
!java/src/**/output/

# .claude/ is generated output of ia-dev-env (source of truth lives at
# java/src/main/resources/targets/claude/). Regenerate locally with the
# generator; do not version the output. Anchored to the repo root so the
# rule does not catch golden test fixtures under
# java/src/test/resources/golden/**/.claude/.
/.claude/

# x-release transient state files (created in Step 0, deleted in Step 12)
/plans/release-state-*.json

# Telemetry NDJSON is a local execution log (generated by
# .claude/hooks/telemetry-*.sh). It is not part of epic deliverables
# and must not be versioned. One generic rule covers every epic —
# replaces the former per-epic rules (e.g., plans/epic-0048/telemetry/*).
plans/epic-*/telemetry/events.ndjson
