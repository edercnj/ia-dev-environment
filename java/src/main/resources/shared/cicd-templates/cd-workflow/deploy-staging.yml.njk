name: Deploy Staging — {{ project_name }}

# Git Flow: Staging deploys from develop (integration branch)
on:
  push:
    branches: [develop]
  workflow_dispatch:

env:
  IMAGE_NAME: ghcr.io/{% verbatim %}${{ github.repository }}{% endverbatim %}/{{ project_name }}
  ENVIRONMENT: staging

jobs:
  build-and-test:
    runs-on: ubuntu-latest
    steps:
      - name: Checkout
        uses: actions/checkout@v4
{% if language_name == "java" or language_name == "kotlin" %}

      - name: Set up JDK {{ language_version }}
        uses: actions/setup-java@v4
        with:
          distribution: temurin
          java-version: "{{ language_version }}"

      - name: Build
        run: {{ build_cmd }}

      - name: Test
        run: {{ test_cmd }}
{% endif %}
{% if language_name == "typescript" %}

      - name: Set up Node.js {{ language_version }}
        uses: actions/setup-node@v4
        with:
          node-version: "{{ language_version }}"
          cache: npm

      - name: Install dependencies
        run: npm ci

      - name: Build
        run: {{ build_cmd }}

      - name: Test
        run: {{ test_cmd }}
{% endif %}
{% if language_name == "python" %}

      - name: Set up Python {{ language_version }}
        uses: actions/setup-python@v5
        with:
          python-version: "{{ language_version }}"

      - name: Install dependencies
        run: pip install -e ".[dev]"

      - name: Test
        run: {{ test_cmd }}
{% endif %}
{% if language_name == "go" %}

      - name: Set up Go {{ language_version }}
        uses: actions/setup-go@v5
        with:
          go-version: "{{ language_version }}"

      - name: Build
        run: {{ build_cmd }}

      - name: Test
        run: {{ test_cmd }}
{% endif %}
{% if language_name == "rust" %}

      - name: Set up Rust
        uses: dtolnay/rust-toolchain@stable

      - name: Build
        run: {{ build_cmd }}

      - name: Test
        run: {{ test_cmd }}
{% endif %}

  deploy:
    runs-on: ubuntu-latest
    needs: build-and-test
    environment: staging
    steps:
      - name: Checkout
        uses: actions/checkout@v4

      - name: Set up Docker Buildx
        uses: docker/setup-buildx-action@v3

      - name: Log in to Container Registry
        uses: docker/login-action@v3
        with:
          registry: ghcr.io
          username: {% verbatim %}${{ github.actor }}{% endverbatim %}
          password: {% verbatim %}${{ secrets.GITHUB_TOKEN }}{% endverbatim %}

      - name: Build & Push Image
        uses: docker/build-push-action@v5
        with:
          context: .
          push: true
          tags: |
            {% verbatim %}${{ env.IMAGE_NAME }}{% endverbatim %}:staging-{% verbatim %}${{ github.sha }}{% endverbatim %}
            {% verbatim %}${{ env.IMAGE_NAME }}{% endverbatim %}:staging-latest

      - name: Deploy to staging
        run: |
          echo "Deploying {% verbatim %}${{ env.IMAGE_NAME }}{% endverbatim %}:staging-{% verbatim %}${{ github.sha }}{% endverbatim %} to staging"
          # Replace with actual deployment command

  smoke-tests:
    runs-on: ubuntu-latest
    needs: deploy
    steps:
      - name: Checkout
        uses: actions/checkout@v4

      - name: Run smoke tests
        run: |
          echo "Running smoke tests against staging"
          # Replace with actual smoke test command
