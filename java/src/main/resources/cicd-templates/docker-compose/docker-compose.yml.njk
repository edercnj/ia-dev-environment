version: "3.9"

services:
  {{ project_name }}:
    build:
      context: .
      dockerfile: Dockerfile
    ports:
      - "{{ framework_port }}:{{ framework_port }}"
    environment:
      - APP_ENV=development
{% if database_name != "none" %}
      - DATABASE_URL={{ database_name }}://dbuser:dbpass@db:5432/{{ project_name }}
{% endif %}
{% if cache_name != "none" %}
      - CACHE_URL={{ cache_name }}://cache:6379
{% endif %}
{% if database_name != "none" or cache_name != "none" %}
    depends_on:
{% endif %}
{% if database_name != "none" %}
      - db
{% endif %}
{% if cache_name != "none" %}
      - cache
{% endif %}
{% if database_name != "none" %}

  db:
    image: {{ database_name }}:latest
    ports:
      - "5432:5432"
    environment:
      - POSTGRES_DB={{ project_name }}
      - POSTGRES_USER=dbuser
      - POSTGRES_PASSWORD=dbpass
    volumes:
      - db-data:/var/lib/postgresql/data
{% endif %}
{% if cache_name != "none" %}

  cache:
    image: {{ cache_name }}:latest
    ports:
      - "6379:6379"
{% endif %}
{% if architecture_style == "cqrs" %}

  eventstore:
    image: eventstore/eventstore:latest
    ports:
      - "2113:2113"
      - "1113:1113"
    environment:
      - EVENTSTORE_INSECURE=true
      - EVENTSTORE_CLUSTER_SIZE=1
      - EVENTSTORE_RUN_PROJECTIONS=All
      - EVENTSTORE_START_STANDARD_PROJECTIONS=true
    volumes:
      - eventstore-data:/var/lib/eventstore
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:2113/health/live"]
      interval: 10s
      timeout: 5s
      retries: 5
      start_period: 15s
{% endif %}
{% if database_name != "none" or cache_name != "none" or architecture_style == "cqrs" %}

volumes:
{% endif %}
{% if database_name != "none" %}
  db-data:
{% endif %}
{% if architecture_style == "cqrs" %}
  eventstore-data:
{% endif %}
