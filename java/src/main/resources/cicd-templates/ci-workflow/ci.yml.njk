name: CI — {{ project_name }}

on:
  push:
    branches: [main, develop]
  pull_request:
    branches: [main]

env:
  CI: true

jobs:
  build-and-test:
    runs-on: ubuntu-latest

    steps:
      - name: Checkout
        uses: actions/checkout@v4
{% if language_name == "java" or language_name == "kotlin" %}

      - name: Set up JDK {{ language_version }}
        uses: actions/setup-java@v4
        with:
          distribution: temurin
          java-version: "{{ language_version }}"
{% if build_tool == "gradle" %}

      - name: Cache Gradle packages
        uses: actions/cache@v4
        with:
          path: |
            ~/.gradle/caches
            ~/.gradle/wrapper
          key: {% verbatim %}${{ runner.os }}{% endverbatim %}-gradle-{% verbatim %}${{ hashFiles('**/*.gradle*', '**/gradle-wrapper.properties') }}{% endverbatim %}
{% endif %}
{% if build_tool == "maven" %}

      - name: Cache Maven packages
        uses: actions/cache@v4
        with:
          path: ~/.m2/repository
          key: {% verbatim %}${{ runner.os }}{% endverbatim %}-maven-{% verbatim %}${{ hashFiles('**/pom.xml') }}{% endverbatim %}
{% endif %}
{% endif %}
{% if language_name == "typescript" %}

      - name: Set up Node.js {{ language_version }}
        uses: actions/setup-node@v4
        with:
          node-version: "{{ language_version }}"
          cache: npm

      - name: Install dependencies
        run: npm ci
{% endif %}
{% if language_name == "python" %}

      - name: Set up Python {{ language_version }}
        uses: actions/setup-python@v5
        with:
          python-version: "{{ language_version }}"

      - name: Install dependencies
        run: pip install -e ".[dev]"
{% endif %}
{% if language_name == "go" %}

      - name: Set up Go {{ language_version }}
        uses: actions/setup-go@v5
        with:
          go-version: "{{ language_version }}"
{% endif %}
{% if language_name == "rust" %}

      - name: Set up Rust
        uses: dtolnay/rust-toolchain@stable

      - name: Cache Cargo registry
        uses: actions/cache@v4
        with:
          path: |
            ~/.cargo/registry
            ~/.cargo/git
            target
          key: {% verbatim %}${{ runner.os }}{% endverbatim %}-cargo-{% verbatim %}${{ hashFiles('**/Cargo.lock') }}{% endverbatim %}
{% endif %}

      - name: Lint
        run: {{ lint_cmd }}

      - name: Build
        run: {{ build_cmd }}

      - name: Test
        run: {{ test_cmd }}

      - name: Coverage
        run: {{ coverage_cmd }}
{% if container == "docker" %}

  image-scan:
    runs-on: ubuntu-latest
    needs: build-and-test
    steps:
      - name: Checkout
        uses: actions/checkout@v4

      - name: Build Docker image
        run: docker build -t {{ project_name }}:{% verbatim %}${{ github.sha }}{% endverbatim %} .

      - name: Run Trivy vulnerability scanner
        uses: aquasecurity/trivy-action@0.28.0
        with:
          image-ref: {{ project_name }}:{% verbatim %}${{ github.sha }}{% endverbatim %}
          format: table
          exit-code: "1"
          severity: CRITICAL,HIGH
{% endif %}
