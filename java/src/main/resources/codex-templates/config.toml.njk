# Codex CLI configuration for {{ project_name }}
# Generated by ia-dev-environment -- do not edit manually.
# WARNING: This file may contain secrets (API keys, tokens). Add to .gitignore.

model = "{{ model }}"
approval_policy = "{{ approval_policy }}"

[sandbox]
mode = "{{ sandbox_mode }}"
{%- if mcp_servers is not empty %}
{% for server in mcp_servers %}

[mcp_servers.{{ server.id }}]
command = [{% for part in server.command %}"{{ part }}"{% if not loop.last %}, {% endif %}{% endfor %}]
{% if server.env is not null %}
[mcp_servers.{{ server.id }}.env]
{% for entry in server.env %}{{ entry.key }} = "{{ entry.value }}"
{% endfor %}
{%- endif %}
{%- endfor %}
{%- endif %}
{%- if agents_list is not empty %}
{% for agent in agents_list %}

[agents.{{ agent.name }}]
description = "{{ agent.description }}"
{% endfor %}
{%- endif %}
